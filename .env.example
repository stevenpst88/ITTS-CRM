# ════════════════════════════════════════
#  ITTS CRM 環境變數範本
#  部署到 Vercel 時請在 Project Settings → Environment Variables 設定
# ════════════════════════════════════════

# ── 執行環境 ──
NODE_ENV=production

# ── Session / JWT 簽章金鑰（64 字元 hex，自行產生）──
# 產生指令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_64_char_hex_secret_here
JWT_SECRET=your_64_char_hex_secret_here

# ── 資料庫後端切換 ──
# 'json'     → 本地 data.json（開發用）
# 'postgres' → Supabase Postgres（正式用）
DB_BACKEND=postgres

# ── Supabase 設定 ──
# Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Supabase Postgres 直連字串
# Dashboard → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxxx.supabase.co:5432/postgres

# ── 檔案儲存後端切換 ──
# 'local'    → ./uploads/（開發用）
# 'supabase' → Supabase Storage（正式用）
STORAGE_BACKEND=supabase
SUPABASE_BUCKET=uploads

# ── CORS 允許來源（部署後改成自己的域名）──
CORS_ORIGIN=https://your-app.vercel.app
